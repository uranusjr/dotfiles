[include]
	path = .gitconfig_site/_.properties
[user]
	name = Tzu-ping Chung
	email = uranusjr@gmail.com
	username = uranusjr
[credential "https://github.com"]
	username = uranusjr
[core]
	editor = vim
	excludesfile = ~/.gitignore_global
	quotepath = false
[gui]
	encoding = utf-8
[i18n "commit"]
	encoding = utf-8
[i18n]
	logoutputencoding = utf-8
[color]
	log = auto
	branch = true
	status = true
	diff = true
	ui = true
    interactive = true
[branch]
    sort = -committerdate
[diff]
    algorithm = histogram
    colorMoved = true
[commit]
    verbose = true
[merge]
    conflictstyle = zdiff3
[rebase]
    autosquash = true
    autostash = true
[pull]
	ff = only
[push]
	default = simple
[pager]
	diff = diff-so-fancy | less --tabs=4 -RFX
	show = diff-so-fancy | less --tabs=4 -RFX
[alias]
	s = status
	ad = add
	st = status
	ci = commit
	co = checkout
	unstage = reset HEAD --
	uncommit = reset HEAD^
	br = branch
	cp = cherry-pick
	dif = diff
	bf = "!f() { b=$(git symbolic-ref --short HEAD); git co -q $1; git br -f $b $1; git co $b; }; f" 
	graph = log --graph --decorate --oneline --all
	gr = log --graph --decorate --oneline --all
	git = !git
	gut = !git
	got = !git
	satsh = stash
	recent-branches = "!f() { git for-each-ref --sort=-committerdate refs/heads/ --format='%(refname:short)' | head; }; f"
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[gpg]
	program = C:\\Users\\uranusjr\\AppData\\Local\\Programs\\Scoop\\apps\\git\\current\\usr\\bin\\gpg.exe
[init]
	defaultBranch = main
